# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Database (MySQL) ──────────────────────────────────────────
# On Railway, these are injected by the linked MySQL service
# (DB_HOST=${{MySQL.MYSQLHOST}}, DB_PORT=${{MySQL.MYSQLPORT}},
# DB_USER=${{MySQL.MYSQLUSER}}, DB_PASSWORD=${{MySQL.MYSQLPASSWORD}},
# DB_NAME=${{MySQL.MYSQLDATABASE}}) as Railway service variables.
# dotenv does NOT override variables that already exist in process.env,
# so these local placeholders are only used when running outside Railway.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=social442
DB_POOL_SIZE=10

# ── JWT ───────────────────────────────────────────────────────
# Generated with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=8f1a7c2e934bd5061f7a3c9d2e4b6f81a0c5d7e93b2f4a6c8d1e0f3b5a7c9d2e1f4a6b8c0d2e4f6a8b1c3d5e7f9a0b2c4d6e8f0a1b3c5d7e9f0a2b4c6d8e0f1a3
JWT_EXPIRES_IN=15m

REFRESH_SECRET=2b4d6f8a0c1e3f5a7b9d0c2e4f6a8b0d1c3e5f7a9b0c2d4e6f8a0b1c3d5e7f9a1b3c5d7e9f0a2c4e6f8a0b2d4f6a8c0e2f4a6b8d0c2e4f6a8b0d2e4f6a8c0e2f4
REFRESH_EXPIRES=7d

# ── CORS ──────────────────────────────────────────────────────
# Set to the deployed frontend origin in production.
CLIENT_ORIGIN=http://localhost:5173

# ── Frontend (Vite) ───────────────────────────────────────────
# Add these to your frontend .env (or .env.local) file:
# VITE_API_BASE_URL=http://localhost:3001/api
# VITE_SOCKET_URL=http://localhost:3001

# ── Media storage (Area 5) ────────────────────────────────────
# Driver: 'local' (default, writes to ./uploads) or 'r2'/'s3'.
STORAGE_DRIVER=local
# Local driver only — where files are written (defaults to ./uploads):
# UPLOAD_DIR=/abs/path/to/uploads
#
# Cloudflare R2 / S3 driver (ratified decision D4). R2 is S3-compatible, so the
# same vars work for AWS S3 (swap the endpoint + region).
# STORAGE_DRIVER=r2
# R2_BUCKET=social442-media
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_REGION=auto
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_PUBLIC_BASE=https://cdn.yourdomain.com   # public/CDN base for objects
#
# NOTE: image processing needs the 'sharp' npm package (installed via
# package.json). Audio/video duration + video poster frames use ffmpeg — install
# system ffmpeg (e.g. `choco install ffmpeg` on Windows, `brew install ffmpeg`
# on macOS, `apt install ffmpeg` on Linux). If ffmpeg is absent, audio/video
# still upload; duration/dimensions just come back null.
