{
  "name": "social442",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "server:watch": "node --watch server/index.js",
    "dev:full": "concurrently \"npm run server:watch\" \"npm run dev\"",
    "kill:server": "node -e \"const { execSync } = require('child_process'); try { const pid = execSync('lsof -ti:3001').toString().trim(); if (pid) { execSync('kill -9 ' + pid); console.log('Killed PID', pid); } } catch(e) { console.log('No process on 3001'); }\"",
    "restart": "npm run kill:server && npm run server:watch",
    "migrate": "node scripts/migrate.mjs",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "animate.css": "^4.1.1",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "emoji-picker-react": "^4.12.0",
    "express": "^5.1.0",
    "file-type": "^22.0.1",
    "fluent-ffmpeg": "^2.1.3",
    "i18next": "^26.3.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-easy-crop": "^5.0.0",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
